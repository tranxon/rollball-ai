{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/schema.json",
  "productName": "Rollball",
  "version": "0.1.0",
  "identifier": "com.rollball.desktop",
  "build": {
    "beforeDevCommand": "cargo build --manifest-path ../../core/Cargo.toml -p rollball-gateway -p rollball-runtime -p rollball-embed && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cargo build --release --manifest-path ../../core/Cargo.toml -p rollball-gateway -p rollball-runtime -p rollball-embed && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "main-capability"
      ]
    },
    "windows": [
      {
        "title": "Rollball",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "windowEffects": {
          "effects": [
            "acrylic",
            "blur",
            "mica"
          ],
          "radius": 12
        }
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../examples/system-agent": "system-agent",
      "../../../assets/offline_providers.json": "offline_providers.json",
      "bin/*": "./"
    }
  }
}